{
  "sonarqube": {
    "command": "docker",
    "args": [
      "run",
      "-i",
      "--rm",
      "-v",
      "archon-sonar-mcp:/app/storage",
      "-e",
      "SONARQUBE_TOKEN",
      "-e",
      "SONARQUBE_ORG",
      "mcp/sonarqube"
    ],
    "env": {
      "SONARQUBE_TOKEN": "$SONAR_TOKEN",
      "SONARQUBE_ORG": "$SONAR_ORG"
    }
  }
}
